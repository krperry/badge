ent remap + COM scan direction\n    if on:\n        oled_cmd(0xA1)  # SEGREMAP\n        oled_cmd(0xC8)  # COMSCANDEC\n    else:\n        oled_cmd(0xA0)  # normal\n        oled_cmd(0xC0)  # normal\n\n\n# --- Your badge code ---\n# turn ON display\nOD01.display(True)\n\n# flip the display so text is upside down\noled_upside_down(True)\n\n# set text size 1 or 2\nOD01.set2_x()\n\n# set zoom level in or out\nOD01.zoom_in()\n\n# clear the display in case of garbage on screen\nOD01.clear()\n\n# write your text\nOD01.show_string(\"Jason\", 0, 0, 1)\nOD01.show_string(\"Martin\", 0, 1, 1)\n\n# sit in loop forever\ndef on_forever():\n    pass\n\nbasic.forever(on_forever)"]]}]}]},{"timestamp":1772497381835,"editorVersion":"8.0.18","changes":[{"type":"edited","filename":"main.py","patch":[{"start1":0,"length1":484,"diffs":[[1,"        # turn ON display, this is default, but doesn't hurt OD01.display(True) # set text size 1 or 2 OD01.set2_x() # set zoom level in or out OD01.zoom_in() # clear the display in case of garbage on screen OD01.clear() # print hello world on screen with OD01.show_string(\"Jason\", 0, 0, 1) OD01.show_string(\"Martin\",0, 1, 1) # sit in loop forever... def on_forever(): pass basic.forever(on_forever)"]]}]}]},{"timestamp":1772497975220,"editorVersion":"8.0.18","changes":[{"type":"edited","filename":"main.py","patch":[{"start1":0,"length1":415,"diffs":[[1,"        # turn ON display, this is default, but doesn't hurt \n        OD01.display(True) \n        # set text size 1 or 2 \n        OD01.set2_x() \n        # set zoom level in or out \n        OD01.zoom_in() \n        # clear the display in case of garbage on screen \n        OD01.clear() \n        # print hello world on screen with \n        OD01.show_string(\"Ken Perry\", 0, 0, 1) OD01.show_string(\"Martin\",0, 1, 1) # sit in loop forever... def on_forever(): pass basic.forever(on_forever)"]]}]}]},{"timestamp":1772498265201,"editorVersion":"8.0.18","changes":[{"type":"edited","filename":"main.ts","patch